# HealthAI Companion Production Environment Configuration Blueprint
# Make sure to copy this file to .env.local for local dev testing
# Never check your active secret key files (.env or .env.local) into version control.

# AI Services Integration
# API key for your LLM inference provider (e.g. OpenAI, Anthropic, Gemini, or custom deployment)
AI_API_KEY=your_production_llm_api_key_here

# Persistence Layer
# Connection string for your secure production database (e.g. PostgreSQL, MongoDB, or MySQL)
DATABASE_URL=postgresql://db_user:db_password@db_host:5432/healthai_companion?sslmode=require

# Authentication & Session Security
# A random secret string used to sign session cookies and JWT tokens securely
AUTH_SECRET=generate_a_secure_auth_jwt_signing_secret_here
